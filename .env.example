# =============================================================================
# AET-SE Environment Configuration
# Copy this to .env and fill in values
# =============================================================================

# --- Ollama Configuration ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=llama3.1:8b-instruct-q4_K_M
OLLAMA_FALLBACK_MODEL=phi3:mini
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_MAX_RETRIES=3

# --- Embedding Model ---
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDING_DEVICE=cpu

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=meddra_pts

# --- DuckDB ---
DUCKDB_PATH=./data/duckdb/faers.duckdb

# --- Data Paths ---
FAERS_RAW_DIR=./data/raw/faers
FAERS_QUARTERS=2024Q4,2025Q1
REVIEWS_RAW_DIR=./data/raw/reviews
RXNORM_DATA_DIR=./data/raw/rxnorm

# --- Cache ---
LLM_CACHE_DIR=./data/cache/llm_extractions
EMBEDDING_CACHE_DIR=./data/cache/embeddings

# --- Evaluation ---
GROUND_TRUTH_DIR=./data/ground_truth
EVAL_RESULTS_DIR=./data/eval_results

# --- Streamlit ---
STREAMLIT_PORT=8501
STREAMLIT_THEME=dark

# --- Logging ---
LOG_LEVEL=INFO
LOG_DIR=./logs

# --- Processing ---
MAX_REVIEWS_TO_PROCESS=30000
BATCH_SIZE=50
CONFIDENCE_THRESHOLD=0.75

# --- Kaggle (for dataset download) ---
KAGGLE_USERNAME=
KAGGLE_KEY=

# --- Resource Limits (important for 8GB RAM systems) ---
DUCKDB_MEMORY_LIMIT=2GB
DUCKDB_THREADS=4
CHROMA_BATCH_SIZE=100
